# Pet chat (/api/pet). Copy to .env.local and fill in.

# Groq API key for the pet's replies. https://console.groq.com/keys
GROQ_API_KEY=

# Origin allowed to call /api/pet. Defaults to http://localhost:3000 in dev;
# set to the deployed site origin in production (e.g. https://denys.sh).
PET_ALLOWED_ORIGIN=
